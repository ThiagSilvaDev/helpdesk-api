meta {
  name: Login [200 OK]
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{login_email}}",
    "password": "{{login_password}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body?.token) {
    bru.setEnvVar("accessToken", res.body.token);
  }
}

settings {
  encodeUrl: false
  followRedirects: true
  maxRedirects: 5
  timeout: inherit
}
