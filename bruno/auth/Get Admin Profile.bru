meta {
  name: Get Admin Profile
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{adminAccessToken}}
}

script:post-response {
  if (res.status === 200 && res.body?.id) {
    bru.setEnvVar("adminUserId", res.body.id);
  }
}
