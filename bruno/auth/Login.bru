meta {
  name: Login Dev
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{loginDevEmail}}",
    "password": "{{loginDevPassword}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body?.token) {
    bru.setEnvVar("adminAccessToken", res.body.token);
    bru.setEnvVar("accessToken", res.body.token);
  }
}

