meta {
  name: Get Tech Profile
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{technicianAccessToken}}
}

script:post-response {
  if (res.status === 200 && res.body?.id) {
    bru.setEnvVar("devTechnicianId", res.body.id);
  }
}
