meta {
  name: Get All Triage Tickets
  type: http
  seq: 10
}

get {
  url: {{baseUrl}}/api/tickets
  body: none
  auth: inherit
}

params:query {
  priority: TRIAGE
  page: 0
  size: 20
  sort: createdAt,desc
}

headers {
  Authorization: Bearer {{accessToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
