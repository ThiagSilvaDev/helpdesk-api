meta {
  name: Create Ticket
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/users/tickets
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{userAccessToken}}
}

body:json {
  {
    "title": "Server is down",
    "description": "The main server is not responding since 10am"
  }
}

script:post-response {
  if (res.status === 201 && res.body?.id) {
    bru.setEnvVar("createdUserTicketId", res.body.id);
  }
}
