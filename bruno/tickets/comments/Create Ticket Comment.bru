meta {
  name: Create Ticket Comment
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/tickets/1/comments
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{technicianAccessToken}}
}

body:json {
  {
    "content": "I already restarted the printer."
  }
}

script:post-response {
  if (res.status === 201 && res.body?.id) {
    bru.setEnvVar("createdCommentId", res.body.id);
  }
}
