meta {
  name: Update User
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/users/{{createdUserId}}
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "name": "John Doe Updated",
    "email": "{{randomEmail}}",
    "role": "ROLE_ADMIN"
  }
}

script:pre-request {
  const randomStr = Math.random().toString(36).substring(7);
  bru.setEnvVar("randomEmail", `user_${randomStr}@email.com`);
}
